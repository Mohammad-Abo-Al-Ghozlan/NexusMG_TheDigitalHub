# Database - MariaDB
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=nexusmg

# JWT
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# AI Services
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.1-70b-versatile

# External APIs
GITHUB_TOKEN=your_github_token
LinkdAPI_API_KEY=your_LinkdAPI_API_KEY
LINKDAPI_BASE_URL=https://api.linkdapi.com/v1

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=uploads

# OAuth — Sign in with Google (same Web client ID as frontend VITE_GOOGLE_CLIENT_ID)
# Create: Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID → Web application
GOOGLE_CLIENT_ID=

# Public URL for emails (verification links, etc.)
APP_BASE_URL=http://localhost:5173

# Debug
DEBUG=true
