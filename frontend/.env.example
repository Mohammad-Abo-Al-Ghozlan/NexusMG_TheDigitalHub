# Defaults to /api/v1 (proxied in dev via vite.config). Point at full URL if not using the proxy.
VITE_API_URL=http://localhost:8000/api/v1
VITE_APP_NAME=NexusMG

# Sign in with Google — Web client ID (must match backend GOOGLE_CLIENT_ID)
# Google Cloud Console → Credentials → OAuth 2.0 Client ID → copy Client ID
VITE_GOOGLE_CLIENT_ID=
